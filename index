  // Custom cursor
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursor-ring');
  let mx = 0, my = 0, rx = 0, ry = 0;
  document.addEventListener('mousemove', e => {
    mx = e.clientX; my = e.clientY;
    cursor.style.transform = `translate(${mx - 4}px, ${my - 4}px)`;
  });
  function animateRing() {
    rx += (mx - rx - 18) * 0.12;
    ry += (my - ry - 18) * 0.12;
    ring.style.transform = `translate(${rx}px, ${ry}px)`;
    requestAnimationFrame(animateRing);
  }
  animateRing();
  document.querySelectorAll('a, button, .filter-btn, .dot').forEach(el => {
    el.addEventListener('mouseenter', () => { cursor.style.transform += ' scale(2)'; ring.style.opacity = '1'; });
    el.addEventListener('mouseleave', () => { ring.style.opacity = '0.6'; });
  });

  // Scroll reveal
  const revealEls = document.querySelectorAll('.reveal');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.15 });
  revealEls.forEach(el => obs.observe(el));

  // Portfolio filter
  function filterPortfolio(btn, cat) {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.portfolio-item').forEach(item => {
      if (cat === 'all' || item.dataset.cat === cat) {
        item.style.opacity = '1';
        item.style.transform = 'none';
      } else {
        item.style.opacity = '0.2';
        item.style.transform = 'scale(0.97)';
      }
      item.style.transition = 'opacity 0.4s, transform 0.4s';
    });
  }

  // Testimonials
  const testimonials = [
    { text: "Abdullah transformed our home into something truly extraordinary. His attention to detail and ability to balance aesthetics with functionality is unlike anything we've experienced.", author: "— Nadia Khan, Residential Client · DHA Karachi" },
    { text: "The 3D visualizations he created for our restaurant gave us complete confidence before we invested. The final result matched perfectly — our guests always comment on the atmosphere.", author: "— Bilal Raza, Restaurant Owner · Clifton" },
    { text: "Working with Abdullah felt like working with someone who genuinely cared about our vision. He brought ideas we hadn't even imagined and elevated the entire project.", author: "— Sara Hussain, Commercial Client · Karachi" }
  ];
  function showTestimonial(idx) {
    const el = document.getElementById('testimonial-text');
    const auth = document.getElementById('testimonial-author');
    el.style.opacity = '0'; el.style.transform = 'translateY(10px)';
    setTimeout(() => {
      el.textContent = testimonials[idx].text;
      auth.textContent = testimonials[idx].author;
      el.style.transition = 'opacity 0.5s, transform 0.5s';
      el.style.opacity = '1'; el.style.transform = 'none';
    }, 300);
    document.querySelectorAll('.dot').forEach((d, i) => d.classList.toggle('active', i === idx));
  }
  // Auto-rotate testimonials
  let tIdx = 0;
  setInterval(() => { tIdx = (tIdx + 1) % 3; showTestimonial(tIdx); }, 5000);

  // Contact submit
  function handleSubmit() {
    const btn = document.querySelector('.contact-submit');
    btn.textContent = 'Message Sent ✓';
    btn.style.background = '#4A7A5A';
    setTimeout(() => { btn.textContent = 'Send Message →'; btn.style.background = ''; }, 3000);
  }
</script>
</body>
</html>
